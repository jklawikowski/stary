{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "default": {
      "format": "%(asctime)s [%(name)s] %(levelname)s: %(message)s"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "formatter": "default",
      "stream": "ext://sys.stderr"
    }
  },
  "root": {
    "handlers": ["console"],
    "level": "WARNING"
  },
  "loggers": {
    "stary": {
      "level": "INFO",
      "handlers": ["console"],
      "propagate": false
    },
    "dagster": {
      "level": "INFO",
      "handlers": ["console"],
      "propagate": false
    }
  }
}
