{
  "id": null,
  "panels": [
    {
      "description": "Set time picker to any window to count Jenkins API calls in that period.",
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum(increase(calls_total{span_name=\"jenkins.request\"}[$__range]))",
          "instant": true
        }
      ],
      "title": "Total Jenkins Calls (selected range)",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 5,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum(increase(calls_total{span_name=\"jenkins.request\",http_status_code=\"200\"}[$__range]))",
          "instant": true
        }
      ],
      "title": "Success (200)",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 9,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum(increase(calls_total{span_name=\"jenkins.request\",http_status_code=~\"[45]..\"}[$__range]))",
          "instant": true
        }
      ],
      "title": "Errors (4xx/5xx)",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 13,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum(increase(calls_total{span_name=\"jenkins.request\",http_status_code=~\"[45]..\"}[$__range])) / sum(increase(calls_total{span_name=\"jenkins.request\"}[$__range]))",
          "instant": true
        }
      ],
      "title": "Error Rate (4xx/5xx)",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2000
              },
              {
                "color": "red",
                "value": 5000
              }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 17,
        "y": 0
      },
      "id": 5,
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum(increase(duration_milliseconds_sum{span_name=\"jenkins.request\"}[$__range])) / sum(increase(duration_milliseconds_count{span_name=\"jenkins.request\"}[$__range]))",
          "instant": true
        }
      ],
      "title": "Avg Latency",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 3,
        "x": 21,
        "y": 0
      },
      "id": 6,
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "count(count by (http_route) (calls_total{span_name=\"jenkins.request\"}))",
          "instant": true
        }
      ],
      "title": "Distinct Routes",
      "type": "stat"
    },
    {
      "description": "Jenkins API calls over time, colored by HTTP status code.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0,
            "pointSize": 5,
            "stacking": {
              "mode": "normal"
            }
          },
          "decimals": 0,
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "HTTP 200"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "HTTP 401"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "HTTP 404"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "HTTP 5.."
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "id": 10,
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum by (http_status_code) (increase(calls_total{span_name=\"jenkins.request\"}[$__rate_interval]))",
          "interval": "1m",
          "legendFormat": "HTTP {{ http_status_code }}"
        }
      ],
      "title": "Jenkins Calls Over Time (by status)",
      "type": "timeseries"
    },
    {
      "description": "Average Jenkins API response time over time.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5
          },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2000
              },
              {
                "color": "red",
                "value": 5000
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "p99.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [10, 10],
                  "fill": "dash"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "avg.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "id": 11,
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum(rate(duration_milliseconds_sum{span_name=\"jenkins.request\"}[$__rate_interval])) / sum(rate(duration_milliseconds_count{span_name=\"jenkins.request\"}[$__rate_interval]))",
          "interval": "1m",
          "legendFormat": "avg latency"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "histogram_quantile(0.99, sum(rate(duration_milliseconds_bucket{span_name=\"jenkins.request\"}[$__rate_interval])) by (le))",
          "interval": "1m",
          "legendFormat": "p99 latency"
        }
      ],
      "title": "Jenkins Latency (avg & p99)",
      "type": "timeseries"
    },
    {
      "description": "Every combination of endpoint route and status code with call counts.",
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Calls"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "transparent",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "http_method"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Method"
              },
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "http_route"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Job Path"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "http_status_code"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Status"
              },
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "id": 12,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum by (http_method, http_route, http_status_code) (increase(calls_total{span_name=\"jenkins.request\"}[$__range])) > 0",
          "format": "table",
          "instant": true
        }
      ],
      "title": "Calls by Route \u00d7 Status (selected range)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "__name__": true,
              "deployment_environment": true,
              "exported_instance": true,
              "exported_job": true,
              "instance": true,
              "job": true,
              "service_instance_id": true,
              "service_name": true,
              "span_kind": true,
              "span_name": true,
              "status_code": true,
              "telemetry_sdk_language": true,
              "telemetry_sdk_name": true,
              "telemetry_sdk_version": true
            },
            "indexByName": {
              "Value": 3,
              "http_method": 0,
              "http_status_code": 2,
              "http_route": 1
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "desc": true,
                "displayName": "Calls"
              }
            ]
          }
        }
      ],
      "type": "table"
    },
    {
      "description": "Jenkins API calls broken down by job path (route pattern)",
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 23
      },
      "id": 13,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum by (http_route) (increase(calls_total{span_name=\"jenkins.request\"}[$__range])) > 0",
          "instant": true,
          "legendFormat": "{{ http_route }}"
        }
      ],
      "title": "Jenkins Calls by Job Path",
      "type": "piechart"
    },
    {
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 23
      },
      "id": 14,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "topk(10, sum by (http_route) (increase(calls_total{span_name=\"jenkins.request\"}[$__range])))",
          "instant": true,
          "legendFormat": "{{ http_route }}"
        }
      ],
      "title": "Top Jobs by Call Volume",
      "type": "bargauge"
    },
    {
      "description": "Click a trace to see the full Jenkins API call details.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "id": 30,
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "P214B5B846CF3925F"
          },
          "filters": [
            {
              "id": "service-name",
              "operator": "=",
              "scope": "resource",
              "tag": "service.name",
              "value": [
                "stary"
              ]
            },
            {
              "id": "span-name",
              "operator": "=",
              "scope": "span",
              "tag": "name",
              "value": [
                "jenkins.request"
              ]
            }
          ],
          "limit": 20,
          "queryType": "traceqlSearch"
        }
      ],
      "title": "Recent Jenkins Traces (Tempo)",
      "type": "traces"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "stary",
    "jenkins",
    "observability"
  ],
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Stary \u2014 Jenkins API Calls",
  "uid": "stary-jenkins-calls",
  "version": 1
}
