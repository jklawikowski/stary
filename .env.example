# Stary configuration
# Copy this file to .env and fill in the values.

# LLM inference endpoint
#INFERENCE_URL=http://127.0.0.1:3030/v1/chat/completions
INFERENCE_URL=http://host.docker.internal:3030/v1/chat/completions

# Optional per-agent inference URLs (fall back to INFERENCE_URL if empty)
AGENT1_INFERENCE_URL=
AGENT2_INFERENCE_URL=
AGENT3_INFERENCE_URL=

# GitHub personal access token (required for cloning private repos and creating PRs)
GITHUB_TOKEN=

# Jira configuration
JIRA_TOKEN=
JIRA_BASE_URL=https://jira.devtools.intel.com

# Dagster UI base URL – used to construct clickable links to pipeline runs
# in Jira WIP comments.  Set this to the externally-reachable URL of your
# Dagster webserver (no trailing slash).
# Example: https://dagster.example.com  or  http://localhost:3000
DAGSTER_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Proxy configuration (optional)
# ---------------------------------------------------------------------------
# If you are behind a corporate proxy, Docker may inherit HTTP_PROXY /
# HTTPS_PROXY from the host environment or from Docker daemon settings
# (~/.docker/config.json).  This can cause container healthchecks that
# target localhost to be routed through the proxy and fail.
#
# The docker-compose.yaml already sets NO_PROXY for all services, but you
# can override the proxy variables here if needed.
#
# NO_PROXY=0.0.0.0,127.0.0.1,localhost,intel.com,habana-labs.com,dagster-db,dagster,user-deployment,host.docker.internal
# HTTP_PROXY=http://proxy-dmz.intel.com:912/
# HTTPS_PROXY=http://proxy-dmz.intel.com:912/
