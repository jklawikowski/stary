JIRA_BASE_URL=https://jira.devtools.intel.com
GITHUB_TOKEN=foo
JIRA_TOKEN=foo
COPILOT_GITHUB_TOKEN=foo

COPILOT_MODEL=claude-opus-4.6

OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4317
OTEL_SERVICE_NAME=stary

# Comma-separated list of owner/repo patterns allowed for STARY-generated PRs.
# Use owner/* for org-wide access. Empty = deny all (fail-closed).
# Example for VerifAI/XPU repos:
# ALLOWED_REPOS=intel-innersource/frameworks.ai.verifai.validation,intel-innersource/frameworks.ai.validation.workloads,intel-innersource/frameworks.ai.pytorch.gpu-models
ALLOWED_REPOS=

# Jenkins integration (optional) — for analysing XPU test build logs
# JENKINS_ALLOWED_HOSTS=ci.example.com
# JENKINS_USERNAME=
# JENKINS_PASSWORD=
