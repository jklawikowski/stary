# ----- Stary application settings -----
INFERENCE_BACKEND=copilot
COPILOT_GITHUB_TOKEN=
COPILOT_MODEL=gpt-4o
JIRA_BASE_URL=
JIRA_TOKEN=
GITHUB_TOKEN=
REPO_PATH=
DAGSTER_BASE_URL=http://localhost:3000

# ----- Proxy settings (optional) -----
# Set these if you are behind a corporate HTTP proxy.
# Leave empty (or unset) when no proxy is needed.
# HTTP_PROXY=http://your-proxy:port/
# HTTPS_PROXY=http://your-proxy:port/
# http_proxy=http://your-proxy:port/
# https_proxy=http://your-proxy:port/
#
# NO_PROXY should always include the Docker service names so that
# inter-container traffic is never routed through the proxy.
# NO_PROXY=0.0.0.0,127.0.0.1,localhost,dagster-db,dagster,user-deployment,host.docker.internal
# no_proxy=0.0.0.0,127.0.0.1,localhost,dagster-db,dagster,user-deployment,host.docker.internal
